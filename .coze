[project]
requires = ["nodejs-24"]

[dev]
build = ["bash", "-c", "cd frontend && pnpm install"]
run = ["bash", "-c", "cd frontend && pnpm dev"]
deps = ["git"] # -> apt install git

[deploy]
build = ["bash", "-c", "cd frontend && pnpm build"]
run = ["bash", "-c", "cd frontend && pnpm start"]
deps = ["git"] # -> apt install git
