# ===========================================
# PawFinder 宠物领养系统 - 环境变量配置
# ===========================================

# Supabase 配置
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# 支付宝沙箱环境配置
# ===========================================
# 沙箱网关地址（正式环境请改为：https://openapi.alipay.com/gateway.do）
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# 沙箱应用APPID（请替换为你的沙箱APPID）
# 获取地址：https://open.alipay.com/develop/sandbox/app
ALIPAY_APP_ID=2021000000000000

# 支付宝公钥（请替换为你的沙箱公钥）
# 获取地址：沙箱环境 -> 沙箱工具 -> RSA2(SHA256)密钥
ALIPAY_PUBLIC_KEY=MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAxxxxxxxxxxxxxx

# 应用私钥（请替换为你的应用私钥）
# 获取地址：沙箱环境 -> 沙箱工具 -> RSA2(SHA256)密钥
# 注意：私钥请妥善保管，不要泄露或提交到代码仓库
ALIPAY_PRIVATE_KEY=MIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQCxxxxxxxxxxxxxx

# 签名方式（固定为RSA2）
ALIPAY_SIGN_TYPE=RSA2

# 回调地址（支付成功后支付宝异步通知的地址）
ALIPAY_NOTIFY_URL=http://localhost:5000/api/payment/notify

# 返回地址（用户支付完成后跳转的地址）
ALIPAY_RETURN_URL=http://localhost:5000/payment/result

# ===========================================
# 如何获取支付宝沙箱配置
# ===========================================
# 1. 访问 https://open.alipay.com/develop/sandbox/app
# 2. 登录支付宝开发者账号
# 3. 创建应用并获取 APPID
# 4. 使用沙箱工具生成 RSA2 密钥对
# 5. 将公钥配置到沙箱应用，私钥配置到环境变量
